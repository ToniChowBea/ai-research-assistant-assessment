
# Database — admin (seed + audit writes) and read-only (all data_api reads)
DATABASE_URL=postgresql://ra_admin:ra_admin@localhost:5432/research
DATABASE_URL_RO=postgresql://ra_readonly:ra_readonly@localhost:5432/research

# Agent / LLM
LLM_MODEL=openai:gpt-5.2
OPENAI_API_KEY="sk-proj..."
MCP_SERVER_URL=http://localhost:8001/mcp
LANGSMITH_API_KEY="lsv2_pt..."

# Governance
GOVERNANCE_MIN_RECORDS=5

# You can link this up to a langsmith account for full trace.
# Or just use the audit/ endpoint to see persisted traces.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=nhs-research-assistant
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
